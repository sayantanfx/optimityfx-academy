{
  "redirects": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "optimityfx-academy.vercel.app" }
      ],
      "destination": "https://academy.optimityfx.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "optimityfx-academy.vercel.app" }
      ],
      "destination": "https://academy.optimityfx.com/:path*",
      "permanent": true
    }
  ]
}
